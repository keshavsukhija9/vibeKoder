# Auth: JWT secret for session cookies (use a long random string in production)
JWT_SECRET=your-secret-at-least-32-chars-long

# Optional: SQLite database path (default: .vibecoder/vibecoder.db)
# DATABASE_PATH=.vibecoder/vibecoder.db

# --- Ollama. Single base URL for all AI endpoints (embed + generate). Default: http://localhost:11434 ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Models (Ollama). AI features use these; defaults work if you run: ollama pull codellama && ollama pull nomic-embed-text ---
# LLM for code completion (Ctrl+Space). Default: codellama:latest
# VIBECODER_LLM_MODEL=codellama:latest
# Embedding model for "Index codebase for AI" (RAG). Default: nomic-embed-text
# VIBECODER_EMBED_MODEL=nomic-embed-text

# Optional: LanceDB directory (default: .vibecoder/lancedb). One DB file; tables are per-playground.
# VIBECODER_LANCEDB_PATH=.vibecoder/lancedb
